{
  "name": "cemetery-cloud-api",
  "version": "1.0.0",
  "description": "Offline Cemetery Administration Desktop Demo",
  "type": "module",
  "main": "electron-main.cjs",
  "author": "",
  "license": "ISC",
  "scripts": {
    "start": "node server.js",
    "dev-server": "nodemon server.js",
    "dev": "concurrently \"node server.js\" \"wait-on http://127.0.0.1:3000 && electron .\"",
    "electron": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.12",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.11",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "za.genesis.cemetery.demo",
    "productName": "Cemetery Admin Demo",
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
